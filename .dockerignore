# Repo-root Docker build context filter.
# Both frontend/Dockerfile (context = repo root) and any future root-context
# build benefit from a tight context — faster uploads, no .env leak risk,
# cleaner layer caches.

# Secrets and local config
.env
.env.*
!.env.example

# VCS
.git/
.gitignore
.gitattributes
.gitmodules

# Dev-only directories
.claude/
.superpowers/
.vscode/
.idea/
.metals/
.trunk/

# Python tooling caches
__pycache__/
*.py[cod]
.mypy_cache/
.pytest_cache/
.ruff_cache/
.import_linter_cache/

# Frontend-specific caches
frontend/__pycache__/
frontend/.mypy_cache/
frontend/.pytest_cache/
frontend/.import_linter_cache/
frontend/.nicegui/

# Backend-specific caches
backend/__pycache__/
backend/.mypy_cache/
backend/.pytest_cache/

# Logs and runtime artifacts
logs/
*.log

# Docs and images (not needed inside images)
docs/
images/
*.md
!frontend/README.md
!backend/README.md
# vmx is a path dependency; its pyproject.toml's `readme = "README.md"`
# means Poetry needs the README at install time. Re-include the entire
# external/ tree so any path-dep package metadata survives the filter.
!external/**

# OS metadata
.DS_Store
Thumbs.db
