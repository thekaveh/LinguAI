# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# Variables marked "(set by compose)" are injected by docker-compose and do
# not need values here; they are listed only so a non-compose runner can
# discover them.

# --- Database (admin role) ---
DB_PORT=50000
POSTGRES_DB=linguai_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=linguai

# --- Database (application role used by the backend) ---
POSTGRES_DB_HOST=db
POSTGRES_APP_USER=linguai_app
POSTGRES_APP_PASSWORD=linguai

# --- pgAdmin (db-dashboard) ---
DB_DASHBOARD_PORT=50001
PGADMIN_DEFAULT_EMAIL=admin@linguai.com
PGADMIN_DEFAULT_PASSWORD=linguai

# --- Ollama (only used by docker-compose.yml; the .ollama-localhost
#     and .ollama-none variants source Ollama from the host or omit it) ---
OLLAMA_PORT=50002

# --- LLM providers ---
# OpenAI: leave blank to disable OpenAI-backed LLMs.
OPENAI_API_KEY=
OPENAI_API_ENDPOINT=https://api.openai.com/v1/

# Groq: leave blank to disable Groq-backed LLMs.
GROQ_API_KEY=
GROQ_API_ENDPOINT=https://api.groq.com/v1/

# --- Service ports ---
BACKEND_PORT=50003
FRONTEND_PORT=50004

# Cookie-signing secret for NiceGUI's app.storage.user. The frontend logs a
# warning at startup if the built-in dev default is in use; production
# deployments must override.
FRONTEND_STORAGE_SECRET=linguai-frontend-dev-secret

# --- Logger configuration ---
BACKEND_LOGGER_NAME=LinguAI-BACKEND
BACKEND_LOG_LEVEL=DEBUG
BACKEND_LOG_FILE=/app/logs/backend-app.log
FRONTEND_LOGGER_NAME=LinguAI-FRONTEND
FRONTEND_LOG_LEVEL=INFO
FRONTEND_LOG_FILE=/app/logs/frontend-app.log

# --- Backend debugging ---
# DB_ECHO=true makes SQLAlchemy log every SQL statement (very noisy). Default false.
DB_ECHO=false

# --- Production resource limits (only consumed by docker-compose-gpu-nvidia.prod.yml) ---
# Override for your prod host; defaults below were sized for an r6g.2xlarge-ish box.
PROD_ENV_CPUS=8
PROD_ENV_MEM_LIMIT=20g

# --- Set by docker-compose; uncomment only when running outside compose ---
# APP_CONTEXT distinguishes backend vs frontend for shared-looking utilities.
# APP_CONTEXT=backend
# BACKEND_ENDPOINT is the URL the frontend uses to reach the backend.
# BACKEND_ENDPOINT=http://localhost:50003
# OLLAMA_API_ENDPOINT is where the backend reaches Ollama.
# OLLAMA_API_ENDPOINT=http://localhost:11434
